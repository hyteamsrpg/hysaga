$Common = "Common.ui";

@ContainerBg = PatchStyle(TexturePath: "Common/ContainerPatch.png", Border: 23);
@FadeBg = PatchStyle(TexturePath: "fade_circle.png");
@SepLine = #a6afba(0.20);
@AccentGold = #e1a738;

@TabStyle = TextButtonStyle(
  Default: (
    LabelStyle: (FontSize: 14, TextColor: #96a9be, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true),
    Background: (TexturePath: "Common/HeaderTabBackground.png", Border: 7)
  ),
  Hovered: (
    LabelStyle: (FontSize: 14, TextColor: #c2d3de, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true),
    Background: (TexturePath: "Common/HeaderTabBackground.png", Border: 7)
  ),
  Pressed: (
    LabelStyle: (FontSize: 14, TextColor: #f0de7b, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true),
    Background: (TexturePath: "Common/HeaderTabSelectedBackground.png", Border: 7)
  )
);

@ActiveTabStyle = TextButtonStyle(
  Default: (
    LabelStyle: (FontSize: 14, TextColor: #f0de7b, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true),
    Background: (TexturePath: "Common/HeaderTabSelectedBackground.png", Border: 7)
  ),
  Hovered: (
    LabelStyle: (FontSize: 14, TextColor: #f0de7b, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true),
    Background: (TexturePath: "Common/HeaderTabSelectedBackground.png", Border: 7)
  )
);

@NavBtnStyle = TextButtonStyle(
  Default: (
    LabelStyle: (FontSize: 20, TextColor: #96a9be, VerticalAlignment: Center, HorizontalAlignment: Center, RenderBold: true),
    Background: (TexturePath: "Common/SecondaryButton.png", Border: 12)
  ),
  Hovered: (
    LabelStyle: (FontSize: 20, TextColor: #c2d3de, VerticalAlignment: Center, HorizontalAlignment: Center, RenderBold: true),
    Background: (TexturePath: "Common/SecondaryButtonHovered.png", Border: 12)
  ),
  Pressed: (
    LabelStyle: (FontSize: 20, TextColor: #f0de7b, VerticalAlignment: Center, HorizontalAlignment: Center, RenderBold: true),
    Background: (TexturePath: "Common/SecondaryButtonPressed.png", Border: 12)
  )
);

@ConfirmBtnStyle = TextButtonStyle(
  Default: (
    LabelStyle: (FontSize: 15, TextColor: #bfcdd5, VerticalAlignment: Center, HorizontalAlignment: Center, RenderBold: true, RenderUppercase: true),
    Background: $Common.@DefaultButtonDefaultBackground
  ),
  Hovered: (
    LabelStyle: (FontSize: 15, TextColor: #ffffff, VerticalAlignment: Center, HorizontalAlignment: Center, RenderBold: true, RenderUppercase: true),
    Background: $Common.@DefaultButtonHoveredBackground
  ),
  Pressed: (
    LabelStyle: (FontSize: 15, TextColor: #dddddd, VerticalAlignment: Center, HorizontalAlignment: Center, RenderBold: true, RenderUppercase: true),
    Background: $Common.@DefaultButtonPressedBackground
  )
);

Group {
  Background: #000000(0.45);
  LayoutMode: Center;

  Group #ClassPanel {
    Anchor: (Width: 520, Height: 780);
    Background: @ContainerBg;

    Group {
      Anchor: (Width: 236, Height: 11, Top: -12);
      Background: "Common/ContainerDecorationTop.png";
    }

    Group {
      Anchor: (Full: 0);
      LayoutMode: Top;
      Padding: (Horizontal: 24, Top: 16, Bottom: 16);

      Group #TabBar {
        Anchor: (Height: 36);
        LayoutMode: Left;
        Padding: (Horizontal: 30);

        TextButton #SkillsTabBtn {
          Anchor: (Width: 190, Height: 32);
          Style: @TabStyle;
          Text: "Skills";
        }

        Group {
          Anchor: (Width: 16);
        }

        TextButton #ClassTabBtn {
          Anchor: (Width: 190, Height: 32);
          Style: @ActiveTabStyle;
          Text: "Class";
        }
      }

      Group {
        Anchor: (Height: 6, Top: 8);
        Background: "Common/ContainerSectionSeparator.png";
      }

      Label {
        Style: (FontSize: 13, HorizontalAlignment: Center, TextColor: #96a9be);
        Anchor: (Top: 12);
        Text: "Choose Your Class";
      }

      Group #ClassCarousel {
        Anchor: (Height: 300, Top: 16);
        LayoutMode: Left;
        Padding: (Horizontal: 30);

        TextButton #PrevClassBtn {
          Anchor: (Width: 40, Height: 40);
          Style: @NavBtnStyle;
          Text: "<";
        }

        Group #ClassCenter {
          Anchor: (Width: 312);
          LayoutMode: Top;

          Group #ClassIconArea {
            Anchor: (Width: 240, Height: 240);
            Background: @FadeBg;
            LayoutMode: Center;

            Group #ClassIcon {
              Anchor: (Width: 160, Height: 160);
            }
          }

          Label #ClassName {
            Style: (FontSize: 22, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, RenderUppercase: true, TextColor: #c2d3de);
            MaskTexturePath: "Common/TextGradient.png";
            Anchor: (Top: 8);
            Text: "WARRIOR";
          }
        }

        TextButton #NextClassBtn {
          Anchor: (Width: 40, Height: 40);
          Style: @NavBtnStyle;
          Text: ">";
        }
      }

      Label #ClassDescription {
        Style: (FontSize: 12, HorizontalAlignment: Center, TextColor: #7a8a9e);
        Anchor: (Top: 8);
        Text: "...";
      }

      Group {
        Anchor: (Height: 6, Top: 16);
        Background: "Common/ContainerSectionSeparator.png";
      }

      Label {
        Style: (FontSize: 13, HorizontalAlignment: Center, RenderBold: true, RenderUppercase: true, TextColor: #96a9be);
        Anchor: (Top: 10);
        Text: "Base Stats";
      }

      Label #ClassBaseStats {
        Style: (FontSize: 14, HorizontalAlignment: Center, RenderBold: true, TextColor: @AccentGold);
        MaskTexturePath: "Common/TextGradient.png";
        Anchor: (Top: 6);
        Text: "Strength: +5";
      }

      Group {
        Anchor: (Height: 1, Top: 14);
        Background: @SepLine;
      }

      Label {
        Style: (FontSize: 13, HorizontalAlignment: Center, RenderBold: true, RenderUppercase: true, TextColor: #96a9be);
        Anchor: (Top: 10);
        Text: "Passive Bonus";
      }

      Label #ClassPassive {
        Style: (FontSize: 14, HorizontalAlignment: Center, RenderBold: true, TextColor: @AccentGold);
        MaskTexturePath: "Common/TextGradient.png";
        Anchor: (Top: 6);
        Text: "+10% Max Health";
      }

      Group {
        Anchor: (Height: 1, Top: 14);
        Background: @SepLine;
      }

      Label {
        Style: (FontSize: 13, HorizontalAlignment: Center, RenderBold: true, RenderUppercase: true, TextColor: #96a9be);
        Anchor: (Top: 10);
        Text: "Class Bonus";
      }

      Label #ClassAmplifier {
        Style: (FontSize: 14, HorizontalAlignment: Center, RenderBold: true, TextColor: @AccentGold);
        MaskTexturePath: "Common/TextGradient.png";
        Anchor: (Top: 6);
        Text: "Strength is 50% more effective";
      }

      TextButton #ConfirmClassBtn {
        Anchor: (Width: 220, Height: 40, Top: 30);
        Style: @ConfirmBtnStyle;
        Text: "Confirm Selection";
      }
    }

    Group {
      Anchor: (Width: 236, Height: 11, Bottom: -6);
      Background: "Common/ContainerDecorationBottom.png";
    }
  }
}
